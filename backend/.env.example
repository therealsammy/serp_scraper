# ---- Core infra ----
DATABASE_URL=postgresql+asyncpg://serp:serp@db:5432/serp
REDIS_URL=redis://redis:6379/0

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-string
ADMIN_BOOTSTRAP_EMAIL=samuel.ohiri1@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-now
INVITE_EXPIRE_HOURS=72

# ---- Frontend origin (CORS) ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- Primary search providers ----
BRAVE_API_KEY=

# Apify — real Google results via the managed "Google Search Results Scraper" actor.
# Get a token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ---- Entity extraction (registered-user premium engines; free users use spaCy) ----
# Google Cloud Natural Language API key (true salience). Free 5,000 units/month.
GOOGLE_NL_API_KEY=
# Apify LangExtract actor uses an LLM — bring your own key.
LANGEXTRACT_LLM_PROVIDER=gemini
LANGEXTRACT_LLM_KEY=
LANGEXTRACT_MODEL=gemini-2.5-flash

# ---- Fallback SERP vendors (one legit account each) ----
SERPER_API_KEY=
SCALESERP_API_KEY=
SERPAPI_API_KEY=
